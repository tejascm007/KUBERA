# ============================================================================
# KUBERA STOCK ANALYSIS CHATBOT - ENVIRONMENT VARIABLES
# Copy this file to .env and fill in your values
# ============================================================================

# ============================================================================
# APPLICATION SETTINGS
# ============================================================================
APP_NAME=KUBERA
APP_VERSION=1.0.0
APP_ENV=development
DEBUG=True
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000

# ============================================================================
# SUPABASE DATABASE CONFIGURATION
# ============================================================================
# Get from: Supabase Dashboard → Connect → Connection String → Transaction Pooler
# IMPORTANT: Use port 6543 (Transaction Pooler) for asyncpg compatibility!
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key

POSTGRES_HOST=aws-0-ap-south-1.pooler.supabase.com
POSTGRES_PORT=6543
POSTGRES_USER=postgres.your-project-id
POSTGRES_PASSWORD=your-database-password
POSTGRES_DB=postgres

# Full connection string (alternative)
DATABASE_URL=postgresql://postgres.your-project-id:your-password@aws-0-ap-south-1.pooler.supabase.com:6543/postgres

# Pool settings (keep small for Supabase free tier)
POSTGRES_MIN_POOL_SIZE=2
POSTGRES_MAX_POOL_SIZE=10

# SSL NOTE:
# ssl='require' is hardcoded in app/core/database.py and scripts/init_db.py
# for Supabase compatibility (Supabase mandates SSL on all connections).
# If you are running against a LOCAL PostgreSQL instance that does NOT have
# SSL enabled, change ssl='require' to ssl=False in both files above,
# or enable SSL on your local PostgreSQL instance.

# ============================================================================
# JWT AUTHENTICATION
# ============================================================================
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-secret-key-generate-with-secrets-token-hex-32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ============================================================================
# LLM CONFIGURATION (OpenRouter)
# ============================================================================
# Get from: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-your-openrouter-api-key
OPENROUTER_MODEL=openai/gpt-4o-mini
OPENROUTER_SITE_URL=http://localhost:8000
OPENROUTER_APP_NAME=KUBERA

# ============================================================================
# EMAIL CONFIGURATION (Gmail SMTP)
# ============================================================================
# For Gmail: Enable 2FA → Create App Password
# https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-gmail-app-password
SMTP_FROM_EMAIL=your-email@gmail.com
SMTP_FROM_NAME=KUBERA

# ============================================================================
# OTP SETTINGS
# ============================================================================
OTP_EXPIRE_MINUTES=10
OTP_MAX_ATTEMPTS=3

# ============================================================================
# RATE LIMITING
# ============================================================================
RATE_LIMIT_BURST=10
RATE_LIMIT_PER_CHAT=50
RATE_LIMIT_PER_HOUR=150
RATE_LIMIT_PER_DAY=1000

# ============================================================================
# MCP SERVERS CONFIGURATION
# ============================================================================
PYTHON_EXECUTABLE=python

# ============================================================================
# STOCK DATA APIs (For MCP Servers)
# ============================================================================

# ----- YAHOO FINANCE (FREE - No API Key needed) -----
# yfinance library works without API key
# Suffix for Indian stocks: .NS (NSE), .BO (BSE)
# Example: RELIANCE.NS, TCS.NS, INFY.NS

# ----- FINNHUB (FREE tier: 60 calls/minute) [ACTIVELY USED] -----
# Get from: https://finnhub.io/register
# Used in: news_sent.py — Finnhub company news
FINNHUB_API_KEY=your-finnhub-api-key

# ----- NEWS API (FREE tier: 100 requests/day) [ACTIVELY USED] -----
# Get from: https://newsapi.org/register
# Used in: news_sent.py — general and financial news articles
NEWSAPI_KEY=your-newsapi-key

# ----- ALPHA VANTAGE (FREE tier: 25 requests/day) [FUTURE INTEGRATION] -----
# Get from: https://www.alphavantage.co/support/#api-key
# Planned use: earnings/economic data enrichment
ALPHA_VANTAGE_API_KEY=your-alphavantage-api-key

# ----- MARKETAUX (FREE tier: 100 requests/day) [FUTURE INTEGRATION] -----
# Get from: https://www.marketaux.com/register
# Planned use: financial news with built-in sentiment analysis
MARKETAUX_API_KEY=your-marketaux-api-key

# ----- INDIAN API (For NSE/BSE specific data) [FUTURE INTEGRATION] -----
# Get from: https://indianapi.in/
# Planned use: India-specific stock data (NSE/BSE)
INDIAN_API_KEY=your-indian-api-key

# ============================================================================
# BACKGROUND JOBS
# ============================================================================
PORTFOLIO_UPDATE_FREQUENCY=10
PORTFOLIO_REPORT_FREQUENCY=disabled
PORTFOLIO_REPORT_SEND_TIME=09:00
PORTFOLIO_REPORT_DAY_WEEKLY=1
PORTFOLIO_REPORT_DAY_MONTHLY=1

# ============================================================================
# TIMEZONE
# ============================================================================
TIMEZONE=Asia/Kolkata

# ============================================================================
# LOGGING
# ============================================================================
LOG_LEVEL=INFO
LOG_FILE=logs/kubera.log
